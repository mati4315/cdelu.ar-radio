# ============================================
# Radio Web Node.js - Configuracion
# ============================================

# Puerto y host donde escucha la app
PORT=3000
HOST=0.0.0.0

# === Autenticacion de Source (OBLIGATORIO) ===
# Cambiar por valores FUERTES antes de hacer deploy
SOURCE_USER=butt_source
SOURCE_PASS=replace_with_strong_password

# Nombre del stream (se muestra en /status)
STREAM_NAME=Radio Live

# Timeout en ms para considerar al source desconectado
OFFLINE_TIMEOUT_MS=600000

# Buffer de chunks en memoria para nuevos oyentes
# (mas chunks = menos lag al conectar, mas RAM)
BUFFER_CHUNKS=64

# Limite maximo del buffer en MB (proteccion RAM)
MAX_BUFFER_MB=50

# Carpeta donde se guardan las grabaciones del SRT de OBS en el VPS
RECORDINGS_DIR=/opt/radio-relay/recordings

# Clave de Facebook Live usada por restream.sh
FACEBOOK_KEY=TU_CLAVE_DE_TRANSMISION

# Segunda clave de Facebook Live usada por restream.sh (opcional)
FACEBOOK_KEY_2=TU_SEGUNDA_CLAVE_DE_TRANSMISION

# Passphrase de SRT usada por OBS y restream.sh
SRT_PASSPHRASE=cdelu-radio-2026

